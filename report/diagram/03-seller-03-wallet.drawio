<mxfile host="app.diagrams.net">
  <diagram name="Seller – Ví tiền &amp; Rút tiền" id="s-wallet">
    <mxGraphModel grid="0" pageWidth="800" pageHeight="380">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Seller – Ví tiền &amp; Rút tiền&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="640" height="320" as="geometry"/></mxCell>
        <mxCell id="a" value="Seller" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="145" width="40" height="80" as="geometry"/></mxCell>

        <mxCell id="uc1" value="Xem số dư &amp; lịch sử giao dịch" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="100" width="220" height="55" as="geometry"/></mxCell>
        <mxCell id="uc2" value="Yêu cầu rút tiền" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="245" width="180" height="50" as="geometry"/></mxCell>

        <mxCell id="e1" style="endArrow=none;" edge="1" source="a" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=none;" edge="1" source="a" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Rút tiền <<include>> Xem số dư (cần kiểm tra số dư trước) -->
        <mxCell id="inc1" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc2" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
