<mxfile host="app.diagrams.net">
  <diagram name="Admin – Quản lý Seller &amp; Shipper" id="adm-sellers">
    <mxGraphModel grid="0" pageWidth="1050" pageHeight="520">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Admin – Quản lý Seller &amp; Shipper&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="890" height="460" as="geometry"/></mxCell>
        <mxCell id="a" value="Admin" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="220" width="40" height="80" as="geometry"/></mxCell>

        <!-- Seller -->
        <mxCell id="uc-seller-list"    value="Xem DS đơn đăng ký Seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="100" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-seller-approve" value="Duyệt đơn Seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="60"  width="175" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-seller-reject"  value="Từ chối đơn Seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="160" width="185" height="50" as="geometry"/></mxCell>

        <!-- Shipper -->
        <mxCell id="uc-ship-list"      value="Xem DS đơn đăng ký Shipper" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="310" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ship-approve"   value="Duyệt đơn Shipper" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="280" width="185" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-ship-reject"    value="Từ chối đơn Shipper" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="380" width="190" height="50" as="geometry"/></mxCell>

        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-seller-list" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-ship-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-seller-approve" target="uc-seller-list" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-seller-reject"  target="uc-seller-list" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ship-approve"   target="uc-ship-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext4" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ship-reject"    target="uc-ship-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
