<mxfile host="app.diagrams.net">
  <diagram name="User – Đăng ký vai trò" id="u-apply">
    <mxGraphModel grid="0" pageWidth="950" pageHeight="460">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;User – Đăng ký vai trò (Seller / Shipper)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="790" height="400" as="geometry"/></mxCell>
        <mxCell id="a" value="User" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="190" width="40" height="80" as="geometry"/></mxCell>

        <!-- Seller path -->
        <mxCell id="uc-s1" value="Nộp đơn đăng ký Seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="90" width="195" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-s2" value="Xem trạng thái đơn Seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="90" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-s3" value="Sửa &amp; nộp lại khi bị từ chối" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="205" width="210" height="50" as="geometry"/></mxCell>

        <!-- Shipper path -->
        <mxCell id="uc-sh1" value="Nộp đơn đăng ký Shipper" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="330" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-sh2" value="Xem trạng thái đơn Shipper" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="330" width="210" height="50" as="geometry"/></mxCell>

        <mxCell id="e1" style="endArrow=none;" edge="1" source="a" target="uc-s1"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=none;" edge="1" source="a" target="uc-s2"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=none;" edge="1" source="a" target="uc-sh1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="endArrow=none;" edge="1" source="a" target="uc-sh2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Xem trạng thái <<extend>> Nộp đơn -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-s2"  target="uc-s1"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Sửa + nộp lại <<extend>> Xem trạng thái (khi bị từ chối) -->
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-s3"  target="uc-s2"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-sh2" target="uc-sh1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
