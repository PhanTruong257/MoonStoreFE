<mxfile host="app.diagrams.net">
  <diagram name="Shipper – Quản lý đơn giao" id="sh-shipments">
    <mxGraphModel grid="0" pageWidth="1100" pageHeight="540">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Shipper – Quản lý đơn giao hàng&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="940" height="480" as="geometry"/></mxCell>
        <mxCell id="a" value="Shipper" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="235" width="40" height="80" as="geometry"/></mxCell>

        <!-- Core -->
        <mxCell id="uc-list"    value="Xem DS đơn giao được phân công" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="220" width="225" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-detail"  value="Xem chi tiết đơn giao" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="510" y="220" width="195" height="55" as="geometry"/></mxCell>

        <!-- Extend UCs -->
        <mxCell id="uc-pickup"  value="Nhận đơn&lt;br&gt;(ASSIGNED → PICKED_UP)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="800" y="80"  width="205" height="60" as="geometry"/></mxCell>
        <mxCell id="uc-transit" value="Đang giao&lt;br&gt;(PICKED_UP → IN_TRANSIT)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="800" y="195" width="215" height="60" as="geometry"/></mxCell>
        <mxCell id="uc-done"    value="Giao thành công&lt;br&gt;(IN_TRANSIT → DELIVERED)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="800" y="320" width="225" height="60" as="geometry"/></mxCell>
        <mxCell id="uc-fail"    value="Giao thất bại&lt;br&gt;(IN_TRANSIT → FAILED)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="800" y="430" width="215" height="55" as="geometry"/></mxCell>

        <!-- Actor associations -->
        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Xem chi tiết <<extend>> Xem DS -->
        <mxCell id="ext0" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-detail"  target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Actions <<extend>> Xem chi tiết -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-pickup"  target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-transit" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-done"    target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext4" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-fail"    target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
