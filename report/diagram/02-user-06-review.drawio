<mxfile host="app.diagrams.net">
  <diagram name="User – Đánh giá sản phẩm" id="u-review">
    <mxGraphModel grid="0" pageWidth="750" pageHeight="380">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;User – Đánh giá sản phẩm&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="590" height="320" as="geometry"/></mxCell>
        <mxCell id="a" value="User" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="145" width="40" height="80" as="geometry"/></mxCell>

        <mxCell id="uc1" value="Submit đánh giá (rating + comment)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="105" width="240" height="55" as="geometry"/></mxCell>
        <mxCell id="uc2" value="Xem danh sách đánh giá SP" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="235" width="215" height="50" as="geometry"/></mxCell>

        <mxCell id="e1" style="endArrow=none;" edge="1" source="a" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=none;" edge="1" source="a" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Xem DS đánh giá <<extend>> Submit (cần đơn DELIVERED mới submit được) -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc1" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
