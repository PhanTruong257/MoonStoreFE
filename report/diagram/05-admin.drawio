        <mxCell id="ext-refund-rev"     value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="a-refund"        target="a-revenue"      parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
