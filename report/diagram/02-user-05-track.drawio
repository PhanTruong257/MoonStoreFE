<mxfile host="app.diagrams.net">
  <diagram name="User – Theo dõi đơn hàng" id="u-track">
    <mxGraphModel grid="0" pageWidth="1100" pageHeight="550">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;User – Theo dõi đơn hàng&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="940" height="490" as="geometry"/></mxCell>
        <mxCell id="a" value="User" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="235" width="40" height="80" as="geometry"/></mxCell>

        <!-- Core UCs -->
        <mxCell id="uc-list"   value="Xem DS đơn hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="230" width="170" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-detail" value="Xem chi tiết đơn" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="460" y="230" width="170" height="50" as="geometry"/></mxCell>

        <!-- Extend UCs (right column) -->
        <mxCell id="uc-cancel" value="Hủy đơn hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="740" y="80" width="165" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-refund" value="Yêu cầu hoàn tiền" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="740" y="195" width="175" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-return" value="Yêu cầu đổi/trả hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="740" y="310" width="190" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-chat"   value="Chat với seller từ đơn" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="740" y="420" width="195" height="50" as="geometry"/></mxCell>

        <!-- Actor associations -->
        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Xem chi tiết <<extend>> Xem DS -->
        <mxCell id="ext0" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-detail" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Actions <<extend>> Xem chi tiết -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-cancel" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-refund" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-return" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext4" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-chat"   target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
