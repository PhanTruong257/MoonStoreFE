<mxfile host="app.diagrams.net">
  <diagram name="Use Case - Chatbot AI" id="usecase-chatbot">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- System Boundary -->
        <mxCell id="sb" value="&lt;b&gt;Moon Store – Chatbot AI&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="40" width="640" height="560" as="geometry" />
        </mxCell>

        <!-- Actors -->
        <mxCell id="a-user" value="User" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="40" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a-gemini" value="Google&#10;Gemini API" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="280" width="40" height="80" as="geometry" />
        </mxCell>

        <!-- Use cases (User-facing) -->
        <mxCell id="uc-open" value="Mở khung chatbot" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="220" y="80" width="200" height="55" as="geometry" /></mxCell>
        <mxCell id="uc-ask" value="Đặt câu hỏi tư vấn sản phẩm" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="220" y="180" width="200" height="60" as="geometry" /></mxCell>
        <mxCell id="uc-faq" value="Hỏi FAQ / hướng dẫn sử dụng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="220" y="290" width="200" height="60" as="geometry" /></mxCell>
        <mxCell id="uc-suggest" value="Xem gợi ý sản phẩm phù hợp" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="220" y="400" width="200" height="60" as="geometry" /></mxCell>
        <mxCell id="uc-history" value="Xem lịch sử hội thoại" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="220" y="500" width="200" height="55" as="geometry" /></mxCell>

        <!-- Internal RAG use cases -->
        <mxCell id="uc-retrieve" value="Truy xuất sản phẩm liên quan&#10;(embedding + cosine similarity)" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="200" width="230" height="70" as="geometry" /></mxCell>
        <mxCell id="uc-generate" value="Sinh câu trả lời theo ngữ cảnh&#10;(Gemini 2.5, streaming SSE)" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="540" y="380" width="230" height="70" as="geometry" /></mxCell>

        <!-- Actor associations -->
        <mxCell id="e-open" edge="1" source="a-user" target="uc-open" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-ask" edge="1" source="a-user" target="uc-ask" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-faq" edge="1" source="a-user" target="uc-faq" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-suggest" edge="1" source="a-user" target="uc-suggest" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-history" edge="1" source="a-user" target="uc-history" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- include relationships -->
        <mxCell id="inc-ask-ret" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ask" target="uc-retrieve" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="inc-faq-ret" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-faq" target="uc-retrieve" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="inc-ret-gen" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-retrieve" target="uc-generate" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="inc-suggest-ret" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-suggest" target="uc-retrieve" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Gemini actor association -->
        <mxCell id="e-gemini-gen" edge="1" source="uc-generate" target="a-gemini" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e-gemini-ret" edge="1" source="uc-retrieve" target="a-gemini" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
