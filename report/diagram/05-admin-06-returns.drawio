<mxfile host="app.diagrams.net">
  <diagram name="Admin – Đổi/trả &amp; Dashboard" id="adm-returns">
    <mxGraphModel grid="0" pageWidth="1050" pageHeight="500">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Admin – Đổi/trả &amp; Dashboard&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="890" height="440" as="geometry"/></mxCell>
        <mxCell id="a" value="Admin" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="205" width="40" height="80" as="geometry"/></mxCell>

        <!-- Returns -->
        <mxCell id="uc-ret-list"   value="Xem tất cả yêu cầu đổi/trả" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="120" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ret-detail" value="Xem chi tiết yêu cầu" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="70"  width="200" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ret-force"  value="Can thiệp xử lý (override)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="190" width="210" height="55" as="geometry"/></mxCell>

        <!-- Dashboard -->
        <mxCell id="uc-dash"       value="Xem Dashboard tổng quan" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="320" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-dash-exp"   value="Xuất báo cáo (export)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="340" width="200" height="50" as="geometry"/></mxCell>

        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-ret-list" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-dash"     parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ret-detail" target="uc-ret-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ret-force"  target="uc-ret-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-dash-exp"   target="uc-dash"       parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
