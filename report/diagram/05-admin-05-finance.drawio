<mxfile host="app.diagrams.net">
  <diagram name="Admin – Tài chính" id="adm-finance">
    <mxGraphModel grid="0" pageWidth="950" pageHeight="440">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Admin – Tài chính&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="790" height="380" as="geometry"/></mxCell>
        <mxCell id="a" value="Admin" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="175" width="40" height="80" as="geometry"/></mxCell>

        <mxCell id="uc-wallet"   value="Xem ví tiền Seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="100" width="190" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-withdraw" value="Xem DS yêu cầu rút tiền" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="260" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-approve"  value="Duyệt yêu cầu rút tiền" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="200" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-reject"   value="Từ chối yêu cầu rút tiền" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="310" width="220" height="55" as="geometry"/></mxCell>

        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-wallet"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-withdraw" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Duyệt / từ chối <<extend>> Xem DS rút tiền -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-approve" target="uc-withdraw" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-reject"  target="uc-withdraw" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
