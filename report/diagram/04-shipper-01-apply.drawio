<mxfile host="app.diagrams.net">
  <diagram name="Shipper – Đăng ký" id="sh-apply">
    <mxGraphModel grid="0" pageWidth="800" pageHeight="380">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Shipper – Đăng ký làm Shipper&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="640" height="320" as="geometry"/></mxCell>
        <mxCell id="a" value="Shipper" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="145" width="40" height="80" as="geometry"/></mxCell>

        <mxCell id="uc1" value="Nộp đơn đăng ký (chọn phương tiện)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="90" width="235" height="55" as="geometry"/></mxCell>
        <mxCell id="uc2" value="Xem trạng thái chờ duyệt" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="240" width="210" height="50" as="geometry"/></mxCell>
        <mxCell id="uc3" value="Xem thông báo được duyệt" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="240" width="215" height="50" as="geometry"/></mxCell>

        <mxCell id="e1" style="endArrow=none;" edge="1" source="a" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=none;" edge="1" source="a" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Xem trạng thái <<extend>> Nộp đơn -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc2" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Xem TB duyệt <<extend>> Xem trạng thái (khi admin phê duyệt) -->
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc3" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
