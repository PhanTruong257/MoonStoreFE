<mxfile host="app.diagrams.net">
  <diagram name="Seller – Xử lý đổi/trả hàng" id="s-returns">
    <mxGraphModel grid="0" pageWidth="1000" pageHeight="480">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Seller – Xử lý đổi/trả hàng&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="840" height="420" as="geometry"/></mxCell>
        <mxCell id="a" value="Seller" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="205" width="40" height="80" as="geometry"/></mxCell>

        <mxCell id="uc-list"    value="Xem DS yêu cầu đổi/trả" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="200" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-approve" value="Duyệt yêu cầu" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="100" width="170" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-reject"  value="Từ chối yêu cầu" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="220" width="175" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-receive" value="Xác nhận đã nhận lại hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="360" width="220" height="50" as="geometry"/></mxCell>

        <mxCell id="e1" style="endArrow=none;" edge="1" source="a" target="uc-list"    parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=none;" edge="1" source="a" target="uc-approve" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Duyệt / Từ chối <<extend>> Xem DS -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-approve" target="uc-list"    parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-reject"  target="uc-list"    parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Xác nhận nhận lại <<extend>> Duyệt (sau khi APPROVED) -->
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-receive" target="uc-approve" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
