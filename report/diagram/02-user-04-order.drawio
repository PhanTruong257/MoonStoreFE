<mxfile host="app.diagrams.net">
  <diagram name="User – Đặt hàng &amp; Thanh toán" id="u-order">
    <mxGraphModel grid="0" pageWidth="1200" pageHeight="520">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;User – Đặt hàng &amp; Thanh toán&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="1040" height="460" as="geometry"/></mxCell>
        <mxCell id="a" value="User" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="225" width="40" height="80" as="geometry"/></mxCell>

        <!-- Main UC -->
        <mxCell id="uc-place" value="Đặt đơn" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="460" y="215" width="150" height="50" as="geometry"/></mxCell>
        <!-- Included by Đặt đơn -->
        <mxCell id="uc-addr"  value="Chọn địa chỉ giao hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="100" width="195" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-pay"   value="Chọn phương thức thanh toán" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="700" y="120" width="210" height="55" as="geometry"/></mxCell>
        <!-- Extends Đặt đơn -->
        <mxCell id="uc-vouch" value="Áp mã giảm giá" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="360" width="175" height="50" as="geometry"/></mxCell>
        <!-- Included by Chọn PT TT -->
        <mxCell id="uc-vnpay" value="Thanh toán VNPay" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="960" y="80" width="170" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-qr"    value="Thanh toán QR chuyển khoản" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="960" y="230" width="195" height="55" as="geometry"/></mxCell>

        <!-- Actor associations -->
        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-place" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-addr"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea3" style="endArrow=none;" edge="1" source="a" target="uc-vouch" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- <<include>> -->
        <mxCell id="inc1" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-place" target="uc-addr"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="inc2" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-place" target="uc-pay"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="inc3" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-pay"   target="uc-vnpay" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="inc4" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-pay"   target="uc-qr"    parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- <<extend>> -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-vouch" target="uc-place"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
