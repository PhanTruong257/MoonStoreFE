<mxfile host="app.diagrams.net">
  <diagram name="Admin – Đơn hàng &amp; Shipment" id="adm-orders">
    <mxGraphModel grid="0" pageWidth="1050" pageHeight="500">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Admin – Đơn hàng &amp; Shipment&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="890" height="440" as="geometry"/></mxCell>
        <mxCell id="a" value="Admin" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="205" width="40" height="80" as="geometry"/></mxCell>

        <!-- Orders -->
        <mxCell id="uc-ord-list"   value="Xem tất cả đơn hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="120" width="195" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ord-detail" value="Xem chi tiết đơn hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="70"  width="200" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ord-cancel" value="Hủy đơn hàng (admin)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="190" width="200" height="55" as="geometry"/></mxCell>

        <!-- Shipment -->
        <mxCell id="uc-ship-list"   value="Xem DS Shipment" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="310" width="195" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ship-assign" value="Phân công Shipper" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="310" width="195" height="55" as="geometry"/></mxCell>

        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-ord-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-ship-list"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ord-detail" target="uc-ord-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ord-cancel" target="uc-ord-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ship-assign" target="uc-ship-list"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
