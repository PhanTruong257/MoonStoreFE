<mxfile host="app.diagrams.net">
  <diagram name="Phân rã – Shipper" id="shipper-detail">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- System Boundary -->
        <mxCell id="sb" value="&lt;b&gt;Moon Store – Shipper&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="30" width="1020" height="720" as="geometry" />
        </mxCell>

        <!-- Actor -->
        <mxCell id="a-shipper" value="Shipper" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="40" height="80" as="geometry" />
        </mxCell>
        <mxCell id="note-inherit" value="(Shipper kế thừa toàn bộ&lt;br&gt;use case của User)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="10" y="460" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- ===== GROUP 1: Đăng ký shipper ===== -->
        <mxCell id="grp1" value="Đăng ký Shipper" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="60" width="430" height="280" as="geometry" />
        </mxCell>
        <mxCell id="sh-apply"    value="Nộp đơn đăng ký (chọn phương tiện)" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="180" y="130" width="200" height="55" as="geometry" /></mxCell>
        <mxCell id="sh-pending"  value="Xem trạng thái chờ duyệt"           style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="130" width="170" height="55" as="geometry" /></mxCell>
        <mxCell id="sh-approved" value="Xem thông báo được duyệt"           style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="270" y="250" width="180" height="55" as="geometry" /></mxCell>

        <!-- ===== GROUP 2: Quản lý đơn giao ===== -->
        <mxCell id="grp2" value="Quản lý đơn giao hàng" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="60" width="490" height="580" as="geometry" />
        </mxCell>
        <mxCell id="sh-list"     value="Xem DS đơn được phân công"            style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="660" y="120" width="200" height="55" as="geometry" /></mxCell>
        <mxCell id="sh-detail"   value="Xem chi tiết đơn giao"                style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="120" width="200" height="55" as="geometry" /></mxCell>
        <mxCell id="sh-pickup"   value="Nhận đơn&lt;br&gt;(ASSIGNED → PICKED_UP)"  style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="660" y="240" width="200" height="55" as="geometry" /></mxCell>
        <mxCell id="sh-transit"  value="Đang giao&lt;br&gt;(PICKED_UP → IN_TRANSIT)" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="240" width="210" height="55" as="geometry" /></mxCell>
        <mxCell id="sh-done"     value="Giao thành công&lt;br&gt;(IN_TRANSIT → DELIVERED)" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="660" y="370" width="210" height="60" as="geometry" /></mxCell>
        <mxCell id="sh-fail"     value="Giao thất bại&lt;br&gt;(IN_TRANSIT → FAILED)"     style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="880" y="370" width="210" height="60" as="geometry" /></mxCell>
        <!-- Status flow annotations -->
        <mxCell id="flow1" value="" style="endArrow=block;endFill=1;startArrow=none;fontSize=10;" edge="1" source="sh-pickup" target="sh-transit" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="flow2" value="" style="endArrow=block;endFill=1;startArrow=none;fontSize=10;" edge="1" source="sh-transit" target="sh-done"   parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="flow3" value="" style="endArrow=block;endFill=1;startArrow=none;fontSize=10;" edge="1" source="sh-transit" target="sh-fail"   parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== ACTOR ASSOCIATIONS ===== -->
        <mxCell id="esh-apply"   edge="1" source="a-shipper" target="sh-apply"   parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esh-pending" edge="1" source="a-shipper" target="sh-pending" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esh-list"    edge="1" source="a-shipper" target="sh-list"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esh-detail"  edge="1" source="a-shipper" target="sh-detail"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esh-pickup"  edge="1" source="a-shipper" target="sh-pickup"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esh-done"    edge="1" source="a-shipper" target="sh-done"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esh-fail"    edge="1" source="a-shipper" target="sh-fail"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== INCLUDE / EXTEND ===== -->
        <!-- Xem chi tiết <<extend>> Xem DS (chọn từ danh sách) -->
        <mxCell id="ext-detail-list"    value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="sh-detail"   target="sh-list"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Các cập nhật trạng thái <<extend>> Xem chi tiết đơn -->
        <mxCell id="ext-pickup-det"     value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="sh-pickup"   target="sh-detail"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-done-det"       value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="sh-done"     target="sh-detail"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-fail-det"       value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="sh-fail"     target="sh-detail"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Xem thông báo duyệt <<extend>> Xem trạng thái chờ (khi admin duyệt) -->
        <mxCell id="ext-approved-pend"  value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="sh-approved"  target="sh-pending" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
