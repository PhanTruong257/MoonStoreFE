        <mxCell id="eu-refund"        edge="1" source="a-user" target="u-refund"        parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-return"        edge="1" source="a-user" target="u-return"        parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-chat-order"    edge="1" source="a-user" target="u-chat-order"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-submit-review" edge="1" source="a-user" target="u-submit-review" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-view-reviews"  edge="1" source="a-user" target="u-view-reviews"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-open-conv"     edge="1" source="a-user" target="u-open-conv"     parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-send-msg"      edge="1" source="a-user" target="u-send-msg"      parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-apply-seller"  edge="1" source="a-user" target="u-apply-seller"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-seller-status" edge="1" source="a-user" target="u-seller-status" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-apply-ship"    edge="1" source="a-user" target="u-apply-ship"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== INCLUDE / EXTEND bổ sung ===== -->
        <!-- Đặt đơn <<include>> Chọn địa chỉ và Chọn PT thanh toán -->
        <mxCell id="inc-order-addr"     value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-place-order" target="u-choose-addr" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="inc-order-pay"      value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-place-order" target="u-choose-pay"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Áp mã giảm giá <<extend>> Đặt đơn (tuỳ chọn) -->
        <mxCell id="ext-voucher-order"  value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-voucher"      target="u-place-order" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Chọn PT TT <<include>> VNPay / QR (đã có, giữ nguyên) -->
        <!-- Các UC <<extend>> Xem chi tiết đơn (chỉ hiện khi đúng trạng thái) -->
        <mxCell id="ext-cancel-det"     value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-cancel"       target="u-order-detail" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-refund-det"     value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-refund"        target="u-order-detail" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-return-det"     value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-return"        target="u-order-detail" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ext-chat-det"       value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-chat-order"    target="u-order-detail" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Submit review <<extend>> Xem chi tiết đơn (khi group đã DELIVERED) -->
        <mxCell id="ext-review-det"     value="&lt;&lt;extend&gt;&gt;"  style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-submit-review" target="u-order-detail" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- Thêm vào giỏ <<include>> Xem chi tiết SP (cần xem trước để chọn option) -->
        <mxCell id="inc-cart-detail"    value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-add-cart"      target="u-detail"       parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
