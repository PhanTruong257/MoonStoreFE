<mxfile host="app.diagrams.net">
  <diagram name="Phân rã – User" id="user-detail">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- System Boundary -->
        <mxCell id="sb" value="&lt;b&gt;Moon Store – User&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="30" width="1720" height="1230" as="geometry" />
        </mxCell>

        <!-- Actor -->
        <mxCell id="a-user" value="User" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="610" width="40" height="80" as="geometry" />
        </mxCell>

        <!-- ===== GROUP 1: Tài khoản ===== -->
        <mxCell id="grp1" value="Tài khoản" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="60" width="510" height="270" as="geometry" />
        </mxCell>
        <mxCell id="u-reg"   value="Đăng ký"                style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="180" y="110" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-login" value="Đăng nhập"              style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="360" y="110" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-logout" value="Đăng xuất"             style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="540" y="110" width="110" height="45" as="geometry" /></mxCell>
        <mxCell id="u-profile" value="Xem/sửa thông tin cá nhân" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="180" y="210" width="180" height="45" as="geometry" /></mxCell>
        <mxCell id="u-addr"  value="Quản lý địa chỉ giao hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="400" y="210" width="200" height="45" as="geometry" /></mxCell>

        <!-- ===== GROUP 2: Duyệt sản phẩm ===== -->
        <mxCell id="grp2" value="Duyệt sản phẩm" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="60" width="500" height="270" as="geometry" />
        </mxCell>
        <mxCell id="u-home"   value="Xem trang chủ"           style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="740" y="110" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-filter" value="Lọc theo danh mục"       style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="940" y="110" width="160" height="45" as="geometry" /></mxCell>
        <mxCell id="u-detail" value="Xem chi tiết sản phẩm"   style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="740" y="210" width="170" height="45" as="geometry" /></mxCell>
        <mxCell id="u-review-view" value="Xem đánh giá SP"    style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="960" y="210" width="150" height="45" as="geometry" /></mxCell>
        <!-- extend: Xem đánh giá extends Xem chi tiết SP (hiện tuỳ chọn khi scroll) -->
        <mxCell id="ext-detail-review" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-review-view" target="u-detail" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== GROUP 3: Giỏ hàng ===== -->
        <mxCell id="grp3" value="Giỏ hàng" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1270" y="60" width="540" height="270" as="geometry" />
        </mxCell>
        <mxCell id="u-add-cart"    value="Thêm vào giỏ"          style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1290" y="110" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-update-cart" value="Cập nhật số lượng"      style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1480" y="110" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-del-cart"    value="Xóa sản phẩm khỏi giỏ" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1290" y="210" width="170" height="45" as="geometry" /></mxCell>
        <mxCell id="u-select-cart" value="Chọn items để checkout" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1490" y="210" width="170" height="45" as="geometry" /></mxCell>

        <!-- ===== GROUP 4: Đặt hàng & Thanh toán ===== -->
        <mxCell id="grp4" value="Đặt hàng &amp; Thanh toán" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="390" width="720" height="270" as="geometry" />
        </mxCell>
        <mxCell id="u-choose-addr"  value="Chọn địa chỉ giao hàng"  style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="180" y="440" width="180" height="45" as="geometry" /></mxCell>
        <mxCell id="u-voucher"      value="Áp mã giảm giá"          style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="400" y="440" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-choose-pay"   value="Chọn phương thức TT"     style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="180" y="540" width="170" height="45" as="geometry" /></mxCell>
        <mxCell id="u-place-order"  value="Đặt đơn"                 style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="390" y="560" width="130" height="45" as="geometry" /></mxCell>
        <mxCell id="u-vnpay"        value="Thanh toán VNPay"        style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="570" y="440" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-qr"           value="Thanh toán QR chuyển khoản" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="570" y="560" width="180" height="45" as="geometry" /></mxCell>
        <!-- include: Chọn PT TT → VNPay / QR -->
        <mxCell id="inc-pay-vnpay" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-choose-pay" target="u-vnpay" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="inc-pay-qr"   value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="u-choose-pay" target="u-qr"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== GROUP 5: Theo dõi đơn hàng ===== -->
        <mxCell id="grp5" value="Theo dõi đơn hàng" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="390" width="930" height="270" as="geometry" />
