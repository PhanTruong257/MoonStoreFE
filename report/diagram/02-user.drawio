        <mxCell id="u-order-list"  value="Xem DS đơn hàng"       style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="950"  y="440" width="160" height="45" as="geometry" /></mxCell>
        <mxCell id="u-order-detail" value="Xem chi tiết đơn"     style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1150" y="440" width="160" height="45" as="geometry" /></mxCell>
        <mxCell id="u-cancel"      value="Hủy đơn hàng"          style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1350" y="440" width="150" height="45" as="geometry" /></mxCell>
        <mxCell id="u-refund"      value="Yêu cầu hoàn tiền"     style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1540" y="440" width="160" height="45" as="geometry" /></mxCell>
        <mxCell id="u-return"      value="Yêu cầu đổi/trả hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1350" y="570" width="170" height="45" as="geometry" /></mxCell>
        <mxCell id="u-chat-order"  value="Chat với seller từ đơn" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1540" y="570" width="170" height="45" as="geometry" /></mxCell>

        <!-- ===== GROUP 6: Đánh giá sản phẩm ===== -->
        <mxCell id="grp6" value="Đánh giá sản phẩm" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
