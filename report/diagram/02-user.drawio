        <mxCell id="eu-addr"          edge="1" source="a-user" target="u-addr"          parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-home"          edge="1" source="a-user" target="u-home"          parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-filter"        edge="1" source="a-user" target="u-filter"        parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
