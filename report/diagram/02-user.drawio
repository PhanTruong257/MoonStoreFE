        <mxCell id="eu-del-cart"      edge="1" source="a-user" target="u-del-cart"      parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-select-cart"   edge="1" source="a-user" target="u-select-cart"   parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-choose-addr"   edge="1" source="a-user" target="u-choose-addr"   parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-voucher"       edge="1" source="a-user" target="u-voucher"       parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-choose-pay"    edge="1" source="a-user" target="u-choose-pay"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-place-order"   edge="1" source="a-user" target="u-place-order"   parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-order-list"    edge="1" source="a-user" target="u-order-list"    parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-order-detail"  edge="1" source="a-user" target="u-order-detail"  parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
