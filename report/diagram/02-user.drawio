        <!-- ===== GROUP 7: Chat với seller ===== -->
        <mxCell id="grp7" value="Chat với seller" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="730" width="430" height="210" as="geometry" />
        </mxCell>
        <mxCell id="u-open-conv"  value="Tạo/mở hội thoại với seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="640" y="790" width="190" height="50" as="geometry" /></mxCell>
        <mxCell id="u-send-msg"   value="Gửi &amp; nhận tin nhắn"    style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="860" y="790" width="160" height="50" as="geometry" /></mxCell>

        <!-- ===== GROUP 8: Đăng ký seller / shipper ===== -->
        <mxCell id="grp8" value="Đăng ký vai trò" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#555555;dashed=1;strokeWidth=1.5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1110" y="730" width="720" height="210" as="geometry" />
        </mxCell>
        <mxCell id="u-apply-seller"  value="Nộp đơn đăng ký seller"           style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1130" y="790" width="180" height="50" as="geometry" /></mxCell>
        <mxCell id="u-seller-status" value="Xem trạng thái đơn seller"        style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1340" y="790" width="180" height="50" as="geometry" /></mxCell>
        <mxCell id="u-apply-ship"    value="Nộp đơn đăng ký shipper"          style="ellipse;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1550" y="790" width="180" height="50" as="geometry" /></mxCell>

        <!-- ===== ACTOR ASSOCIATIONS ===== -->
        <mxCell id="eu-reg"           edge="1" source="a-user" target="u-reg"           parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eu-login"         edge="1" source="a-user" target="u-login"         parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
