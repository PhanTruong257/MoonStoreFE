<mxfile host="app.diagrams.net">
  <diagram name="Seller – Quản lý đơn hàng" id="s-orders">
    <mxGraphModel grid="0" pageWidth="1150" pageHeight="560">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Seller – Quản lý đơn hàng&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="990" height="500" as="geometry"/></mxCell>
        <mxCell id="a" value="Seller" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="245" width="40" height="80" as="geometry"/></mxCell>

        <!-- Core -->
        <mxCell id="uc-list"    value="Xem DS đơn hàng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="230" width="170" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-detail"  value="Xem chi tiết đơn" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="470" y="230" width="170" height="50" as="geometry"/></mxCell>

        <!-- Extend UCs -->
        <mxCell id="uc-confirm" value="Xác nhận đơn (CONFIRMED)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="60" width="200" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ship"    value="Chuyển sang SHIPPING" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="165" width="195" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-deliver" value="Xác nhận giao (DELIVERED)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="265" width="205" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-cancel"  value="Hủy đơn (kèm ghi chú)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="365" width="195" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-qr"      value="Xác nhận thanh toán QR" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="455" width="195" height="50" as="geometry"/></mxCell>

        <!-- Actor associations -->
        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Xem chi tiết <<extend>> Xem DS -->
        <mxCell id="ext0" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-detail"  target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Actions <<extend>> Xem chi tiết -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-confirm" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ship"    target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-deliver" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext4" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-cancel"  target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ext5" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-qr"      target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
