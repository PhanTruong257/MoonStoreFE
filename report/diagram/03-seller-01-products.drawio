<mxfile host="app.diagrams.net">
  <diagram name="Seller – Quản lý sản phẩm" id="s-products">
    <mxGraphModel grid="0" pageWidth="1150" pageHeight="520">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Seller – Quản lý sản phẩm&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="990" height="460" as="geometry"/></mxCell>
        <mxCell id="a" value="Seller" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="225" width="40" height="80" as="geometry"/></mxCell>

        <!-- Core -->
        <mxCell id="uc-list"    value="Xem DS sản phẩm" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="100" width="175" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-filter"  value="Lọc theo trạng thái" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="240" width="175" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-delete"  value="Xóa sản phẩm (soft delete)" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="380" width="210" height="50" as="geometry"/></mxCell>

        <!-- Create/Edit -->
        <mxCell id="uc-create"  value="Tạo sản phẩm mới" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="100" width="175" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-edit"    value="Sửa sản phẩm" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="240" width="160" height="50" as="geometry"/></mxCell>

        <!-- Sub UCs (included) -->
        <mxCell id="uc-img"     value="Upload ảnh sản phẩm" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="780" y="100" width="185" height="50" as="geometry"/></mxCell>
        <mxCell id="uc-options" value="Khai báo option groups" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="780" y="240" width="185" height="50" as="geometry"/></mxCell>

        <!-- Actor associations -->
        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-filter" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea3" style="endArrow=none;" edge="1" source="a" target="uc-delete" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea4" style="endArrow=none;" edge="1" source="a" target="uc-create" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea5" style="endArrow=none;" edge="1" source="a" target="uc-edit"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- <<include>> -->
        <mxCell id="inc1" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-create" target="uc-img"     parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="inc2" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-create" target="uc-options" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="inc3" value="&lt;&lt;include&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-edit"   target="uc-img"     parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- <<extend>> -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-filter" target="uc-list" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
