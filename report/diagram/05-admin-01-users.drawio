<mxfile host="app.diagrams.net">
  <diagram name="Admin – Quản lý người dùng" id="adm-users">
    <mxGraphModel grid="0" pageWidth="950" pageHeight="460">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="sb" value="&lt;b&gt;Admin – Quản lý người dùng&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="130" y="30" width="790" height="400" as="geometry"/></mxCell>
        <mxCell id="a" value="Admin" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="30" y="190" width="40" height="80" as="geometry"/></mxCell>

        <mxCell id="uc-list"   value="Xem danh sách người dùng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="190" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-search" value="Tìm kiếm / lọc người dùng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="80"  width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-detail" value="Xem chi tiết người dùng" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="190" width="215" height="55" as="geometry"/></mxCell>
        <mxCell id="uc-ban"    value="Khoá / mở khoá tài khoản" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="530" y="330" width="215" height="55" as="geometry"/></mxCell>

        <mxCell id="ea1" style="endArrow=none;" edge="1" source="a" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=none;" edge="1" source="a" target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Tìm kiếm <<extend>> Xem DS -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-search" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Xem chi tiết <<extend>> Xem DS -->
        <mxCell id="ext2" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-detail" target="uc-list"   parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- Khoá <<extend>> Xem chi tiết -->
        <mxCell id="ext3" value="&lt;&lt;extend&gt;&gt;" style="dashed=1;endArrow=open;endFill=0;startArrow=none;fontSize=10;" edge="1" source="uc-ban"    target="uc-detail" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
