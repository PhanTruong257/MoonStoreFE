        <mxCell id="uc1" value="Tạo / mở hội thoại với Seller" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="95" width="210" height="55" as="geometry"/></mxCell>
        <mxCell id="uc2" value="Gửi tin nhắn" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="240" width="160" height="50" as="geometry"/></mxCell>
        <mxCell id="uc3" value="Nhận tin nhắn realtime" style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="460" y="240" width="185" height="50" as="geometry"/></mxCell>

        <mxCell id="e1" style="endArrow=none;" edge="1" source="a" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
